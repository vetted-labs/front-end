{
  "name": "front-end",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- next dev",
    "build": "NODE_OPTIONS='--no-deprecation' next build",
    "start": "dotenv -e .env.local -- next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:candidate": "playwright test e2e/candidate",
    "test:e2e:hiring": "playwright test e2e/hiring",
    "test:e2e:expert": "playwright test e2e/expert",
    "test:e2e:shared": "playwright test e2e/shared",
    "e2e:bootstrap": "tsx e2e/real-flow/bootstrap/setup-stack.ts",
    "e2e:real-flow": "npx dotenv -e .env.local -- npx playwright test --config=e2e/real-flow/playwright.real-flow.config.ts",
    "test:e2e:guild-feed:real": "npx dotenv -e .env.local -- npx playwright test --config=e2e/real-flow/playwright.real-flow.config.ts e2e/real-flow/scenarios/guild-feed",
    "test:verify-regression-specs": "node scripts/verify-regression-specs.mjs",
    "e2e:experiment": "tsx e2e/real-flow/experiments/run-experiment.ts",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint --fix",
    "security:audit": "npm audit --audit-level=high",
    "check-secrets": "bash scripts/check-secrets.sh",
    "ci": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.0",
    "lucide-react": "^0.546.0",
    "next": "^16.2.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "shiki": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "viem": "^2.37.6",
    "wagmi": "^2.17.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
